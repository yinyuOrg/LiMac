#!/bin/bash
# home-manager-setup.sh - 自动化设置 LiMac Home Manager (动态生成主仓库配置版)

set -e  # 遇到错误立即退出

# 颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

if [ -L ${BASH_SOURCE-$0} ]; then
  FWDIR=$(dirname $(readlink "${BASH_SOURCE-$0}"))
else
  FWDIR=$(dirname "${BASH_SOURCE-$0}")
fi
project_dir="$(cd "${FWDIR}/.."; pwd)"
cd "$project_dir"

# 日志函数
log_info() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

log_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1"
}

log_warning() {
    echo -e "${YELLOW}[WARNING]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

# 检查依赖
check_dependencies() {
    log_info "检查系统依赖..."

    if ! command -v nix &> /dev/null; then
        log_error "Nix 未安装。请先安装 Nix。"
        exit 1
    fi

    if ! command -v git &> /dev/null; then
        log_error "Git 未安装。请先安装 Git。"
        exit 1
    fi

    log_success "依赖检查通过"
}

# 启用 Nix 实验性功能
enable_experimental_features() {
    log_info "启用 Nix 实验性功能..."

    mkdir -p ~/.config/nix
    cat > ~/.config/nix/nix.conf << 'EOF'
experimental-features = nix-command flakes
extra-substituters = https://cache.nixos.org
trusted-public-keys = cache.nixos.org-1:6NCHdD59X431o0gWypbMrAURkbJ16ZPMQFGspcDShjY=
EOF

    log_success "Nix 实验性功能已启用"
}

# 交互式配置并生成 host 文件
generate_host_config() {
    local current_user=$(whoami)
    local platform="linux"
    if [ "$IS_DARWIN" = true ]; then
        platform="darwin"
    fi

    local host_file="hosts/${current_user}.${platform}.nix"

    if [ -f "$host_file" ]; then
        log_info "检测到已存在 Host 配置文件: $host_file，将直接使用该配置。"
        return 0
    fi

    log_info "开始为用户 '$current_user' 创建 Host 配置文件..."

    # 获取 Git 默认信息
    local git_username=""
    local git_email=""

    if command -v git &> /dev/null; then
        git_username=$(git config --global user.name || echo "")
        git_email=$(git config --global user.email || echo "")
    fi

    echo
    log_info "请输入配置信息（按 Enter 使用默认值或现有值）"

    read -p "Git 用户名 [${git_username:-暂无}]: " input_git_username
    git_username=${input_git_username:-$git_username}

    read -p "Git 邮箱 [${git_email:-暂无}]: " input_git_email
    git_email=${input_git_email:-$git_email}

    # 验证必要信息
    if [ -z "$git_username" ]; then
        log_error "Git 用户名是必需的"
        exit 1
    fi

    if [ -z "$git_email" ]; then
        log_error "Git 邮箱是必需的"
        exit 1
    fi

    log_info "正在生成 $host_file..."
    
    mkdir -p hosts

    if [ "$IS_DARWIN" = true ]; then
        cat > "$host_file" << EOF
{
  home.username = "${current_user}";

  programs.git.settings = {
    user.name = "${git_username}";
    user.email = "${git_email}";
  };

  imports = [
    ../home/platforms/darwin.nix
  ];
}
EOF
    else
        cat > "$host_file" << EOF
{
  home.username = "${current_user}";

  programs.git.settings = {
    user.name = "${git_username}";
    user.email = "${git_email}";
  };
}
EOF
    fi

    log_success "Host 配置文件已成功生成: $host_file"
    log_warning "提示: 新生成的配置文件未被 Git 跟踪。由于 Nix Flakes 只读取 Git 跟踪的文件，在继续之前你需要手动执行："
    log_warning "  git add $host_file"
    log_warning "（出于安全考虑，脚本不会自动替你执行此操作）"
    
    echo
    while true; do
        read -p "你是否已经执行了 'git add $host_file'？[y/N]: " is_added
        case "$is_added" in
            [Yy]*)
                break
                ;;
            *)
                log_warning "请先在另一个终端运行: git add $host_file"
                ;;
        esac
    done
}

# 检查 Nix daemon 可访问性（多用户安装常见权限问题）
check_nix_daemon_access() {
    log_info "检查 Nix daemon 连接..."

    if nix store info >/dev/null 2>&1; then
        log_success "Nix daemon 连接正常"
        return 0
    fi

    # 常见 Debian 多用户安装：daemon-socket 目录对 nix-users 组开放
    if [ -d "/nix/var/nix/daemon-socket" ]; then
        local socket_dir="/nix/var/nix/daemon-socket"
        local dir_group
        dir_group=$(stat -c '%G' "$socket_dir" 2>/dev/null || true)

        if [ "$dir_group" = "nix-users" ]; then
            local current_user
            current_user=$(whoami)

            if getent group nix-users | grep -qw "$current_user"; then
                if ! id -nG | grep -qw nix-users; then
                    log_error "当前 shell 未加载 'nix-users' 用户组权限。"
                    log_info "你已经是 'nix-users' 组成员，但当前会话尚未生效。"
                    log_info "请执行以下命令后重新运行本脚本："
                    echo ""
                    echo -e "  ${YELLOW}newgrp nix-users${NC}"
                    echo ""
                    log_info "或者注销并重新登录。"
                    exit 1
                fi
            else
                log_error "当前用户不在 'nix-users' 组中，无法访问 Nix daemon socket。"
                log_info "请执行以下命令（执行后需要注销并重新登录）："
                echo ""
                echo -e "  ${YELLOW}sudo usermod -aG nix-users ${current_user}${NC}"
                echo ""
                exit 1
            fi
        fi
    fi

    log_error "无法连接到 Nix daemon，请检查 Nix 安装状态。"
    exit 1
}

# 应用 Home Manager 配置
apply_home_manager() {
    local current_user=$(whoami)
    local platform="linux"
    if [ "$IS_DARWIN" = true ]; then
        platform="darwin"
    fi

    local config_name="${current_user}.${platform}"

    log_info "应用 Home Manager 配置, 配置名: $config_name"

    # 应用配置
    nix run "nixpkgs#home-manager" -- switch --flake ".#$config_name"

    log_success "Home Manager 配置应用完成"
}

# 配置 Konsole
configure_konsole() {
    if [ "$IS_DARWIN" = true ]; then
        log_info "macOS 跳过 Konsole 配置"
        return
    fi

    if ! command -v konsole &> /dev/null; then
        log_warning "Konsole 未安装，跳过配置"
        return
    fi

    local current_user=$(whoami)
    local fish_path="/home/$current_user/.nix-profile/bin/fish"

    if [ ! -f "$fish_path" ]; then
        log_warning "Fish shell 未找到，跳过 Konsole 配置"
        return
    fi

    log_info "配置 Konsole..."

    # 创建 Konsole 配置目录
    mkdir -p ~/.local/share/konsole

    # 创建自定义 profile
    cat > ~/.local/share/konsole/LiMac.profile << EOF
[General]
Command=$fish_path
Name=LiMac
Parent=FALLBACK/
EOF

    log_success "Konsole 配置已创建"
    log_info "请在 Konsole 中手动选择 LiMac profile:"
    log_info "1. 点击右上角菜单按钮"
    log_info "2. 选择 'Create New Profile...'"
    log_info "3. 选择 LiMac profile"
    log_info "4. 设置为默认 profile (可选)"
}

# 显示完成信息
show_completion() {
    local current_user=$(whoami)
    local platform="linux"
    if [ "$IS_DARWIN" = true ]; then
        platform="darwin"
    fi
    local config_name="${current_user}.${platform}"

    local fish_path
    if [ "$IS_DARWIN" = true ]; then
        fish_path="/Users/$current_user/.nix-profile/bin/fish"
    else
        fish_path="/home/$current_user/.nix-profile/bin/fish"
    fi

    echo
    log_success "Home Manager 设置完成！"
    echo
    log_info "后续操作："
    log_info "1. 格式化配置: nix fmt"
    log_info "2. 更新配置: nix run \"nixpkgs#home-manager\" -- switch --flake .#$config_name"
    log_info "3. 查看新闻: home-manager news"
    echo
    log_info "重要提示："
    log_info "- Fish shell 路径: $fish_path"
    log_info "- 请在终端中手动配置使用此 shell"
    if [ "$IS_DARWIN" = true ]; then
        log_info "- macOS 上请在终端/iTerm2/VSCode 中配置"
    else
        log_info "- 推荐在 Konsole 中设置 LiMac profile"
    fi
    echo
    if [ "$IS_DARWIN" = true ]; then
        log_info "macOS 不支持 systemd，无需清理服务"
    else
        log_info "如果遇到 systemd 服务错误，请运行:"
        log_info "systemctl --user reset-failed"
        log_info "systemctl --user daemon-reload"
    fi
}

# 清理失败的 systemd 服务（预防性）
cleanup_systemd_services() {
    if [ "$IS_DARWIN" = true ]; then
        log_info "macOS 不支持 systemd，跳过清理"
        return
    fi

    log_info "清理可能的 systemd 服务问题..."

    # 重置失败的 systemd 服务
    systemctl --user reset-failed 2>/dev/null || true
    systemctl --user daemon-reload 2>/dev/null || true

    log_success "systemd 服务清理完成"
}

# 主函数
main() {
    echo -e "${BLUE}"
    cat << "EOF"
 _   _               __  __
| | | | ___  _ __   |  \/  | __ _ _ __   __ _  __ _  ___ _ __ ___
| |_| |/ _ \| '_ \  | |\/| |/ _` | '_ \ / _` |/ _` |/ _ \ '__/ __|
|  _  | (_) | |_) | | |  | | (_| | | | | (_| | (_| |  __/ |  \__ \
|_| |_|\___/| .__/  |_|  |_|\__,_|_| |_|\__,_|\__, |\___|_|  |___/
            |_|                               |___/
EOF
    echo -e "${NC}"

    OS_TYPE="$(uname | tr '[:upper:]' '[:lower:]')"
    IS_DARWIN=false
    if [ "$OS_TYPE" = "darwin" ]; then
        IS_DARWIN=true
    fi

    log_info "开始设置 LiMac Home Manager"
    log_info "检测到平台: $(uname) ($OS_TYPE)"

    # 执行步骤
    check_dependencies
    check_nix_daemon_access
    enable_experimental_features
    generate_host_config
    apply_home_manager
    configure_konsole
    cleanup_systemd_services
    show_completion
}

main "$@"
